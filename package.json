{
  "name": "warehouse-management",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "start cmd /k \"cd ../backend && npm run dev\" && expo start",
    "android": "start cmd /k \"cd ../backend && npm run dev\" && expo start --android",
    "ios": "start cmd /k \"cd ../backend && npm run dev\" && expo start --ios",
    "web": "start cmd /k \"cd ../backend && npm run dev\" && expo start --web",
    "predeploy": "npx expo export --platform web",
    "deploy": "gh-pages --nojekyll -d dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-picker/picker": "^2.11.4",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "expo": "~51.0.0",
    "expo-image-picker": "~15.1.0",
    "expo-linear-gradient": "~13.0.2",
    "expo-print": "~13.0.1",
    "expo-sharing": "~12.0.1",
    "expo-status-bar": "~1.12.1",
    "lucide-react-native": "^0.487.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "^3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "3.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "gh-pages": "^6.3.0"
  },
  "private": true
}
